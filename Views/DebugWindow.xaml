<Window x:Class="AstralLite.Views.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AstralLite.ViewModels"
        Title="AstralLite 调试窗口" 
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="CanResize">
    
    <Window.DataContext>
        <vm:DebugViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="HeaderBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3F3F46"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#9E9E9E"/>
        <SolidColorBrush x:Key="TertiaryText" Color="#6A6A6A"/>
        <SolidColorBrush x:Key="AccentColor" Color="#007ACC"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#4CAF50"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#F44336"/>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="{StaticResource HeaderBackground}" CornerRadius="5" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="WFP 状态: " Foreground="{StaticResource SecondaryText}" VerticalAlignment="Center"/>
                    <TextBlock Text="已启用" Foreground="{StaticResource SuccessColor}" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="活动规则: " Foreground="{StaticResource SecondaryText}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActiveRuleCount}" Foreground="{StaticResource AccentColor}" 
                               VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="{StaticResource HeaderBackground}" CornerRadius="5" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="进程状态" Foreground="{StaticResource PrimaryText}" 
                               FontSize="14" FontWeight="SemiBold" Margin="10,8"/>
                    
                    <ListView Grid.Row="1" ItemsSource="{Binding Processes}" 
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource PrimaryText}" MaxHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="8,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding ProcessName}" Foreground="{StaticResource TertiaryText}" FontSize="10"/>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="{StaticResource SuccessColor}" 
                                                   FontSize="11" VerticalAlignment="Center" Margin="10,0"/>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding RulesText}" Foreground="{StaticResource AccentColor}" 
                                                   FontSize="10" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
            
            <Border Grid.Column="1" Background="{StaticResource HeaderBackground}" CornerRadius="5" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="规则列表" Foreground="{StaticResource PrimaryText}" 
                               FontSize="14" FontWeight="SemiBold" Margin="10,8"/>
                    
                    <ListView Grid.Row="1" ItemsSource="{Binding Rules}" 
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource PrimaryText}" MaxHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="8,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding RuleName}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Foreground="{StaticResource TertiaryText}" FontSize="10">
                                                <Run Text="{Binding Action}"/>
                                                <Run Text=" | "/>
                                                <Run Text="{Binding Protocol}"/>
                                                <Run Text=" | "/>
                                                <Run Text="{Binding Port}"/>
                                                <Run Text=" | "/>
                                                <Run Text="{Binding IpVersion}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="1" Text="{Binding StatusText}" 
                                                   Foreground="{StaticResource SuccessColor}" 
                                                   FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
        
        <Border Grid.Row="2" Background="{StaticResource HeaderBackground}" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="事件日志" Foreground="{StaticResource PrimaryText}" 
                               FontSize="14" FontWeight="SemiBold"/>
                    
                    <Button Grid.Column="1" Content="清除" Padding="10,2" 
                            Background="{StaticResource BorderColor}" Foreground="{StaticResource PrimaryText}"
                            BorderThickness="0" Command="{Binding ClearLogsCommand}"/>
                </Grid>
                
                <ListBox Grid.Row="1" ItemsSource="{Binding Logs}" 
                         Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource PrimaryText}"
                         FontFamily="Consolas" FontSize="11">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="5,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="刷新" Padding="15,5" Margin="0,0,10,0"
                    Background="{StaticResource AccentColor}" Foreground="White"
                    BorderThickness="0" Command="{Binding RefreshCommand}"/>
            <Button Content="关闭" Padding="15,5" 
                    Background="{StaticResource BorderColor}" Foreground="{StaticResource PrimaryText}"
                    BorderThickness="0" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
