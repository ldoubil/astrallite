<UserControl x:Class="AstralLite.Views.Controls.RoomListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d">
    
    <UserControl.Resources>
        <DataTemplate x:Key="RoomItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Rectangle Width="3" Height="8" Fill="{DynamicResource SignalColor}" Margin="0,0,1,0"/>
                    <Rectangle Width="3" Height="12" Fill="{DynamicResource SignalColor}" Margin="0,0,1,0"/>
                    <Rectangle Width="3" Height="16" Fill="{DynamicResource SignalColor}" Margin="0,0,1,0"/>
                    <Rectangle Width="3" Height="20" Fill="{DynamicResource SignalColor}"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Name}" 
                               FontSize="12" 
                               Foreground="{DynamicResource PrimaryText}"/>
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding PlayerCount}" 
                                   FontSize="10" 
                                   Foreground="{DynamicResource TertiaryText}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Ping}"
                                   FontSize="10"
                                   Foreground="{DynamicResource SignalColor}"
                                   Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>

                </Grid>
        </DataTemplate>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Disabled"
                  Background="{DynamicResource ListBackground}">
        <StackPanel Visibility="{Binding RoomListVisibility}">
            <!-- CS:GO -->
            <Border Background="{DynamicResource HeaderBackground}" 
                    BorderBrush="{DynamicResource BorderColor}" 
                    BorderThickness="0,1,0,0"
                    Cursor="Hand"
                    MouseLeftButtonDown="GameHeader_Click"
                    Tag="CSGO">
                <Grid Margin="15,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#x25BC;" 
                               FontSize="10" 
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Tag="CollapseIcon"/>
                    <TextBlock Grid.Column="1"
                               Text="Counter-Strike: Global Offensive" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ListBox x:Name="CSGOListBox"
                     ItemsSource="{Binding CSGORooms}"
                     BorderThickness="0"
                     Background="Transparent"
                     ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                     ItemTemplate="{StaticResource RoomItemTemplate}"
                     SelectionMode="Single"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="RoomList_DoubleClick"/>

            <!-- PayDay 2 -->
            <Border Background="{DynamicResource HeaderBackground}" 
                    BorderBrush="{DynamicResource BorderColor}" 
                    BorderThickness="0,1,0,0"
                    Cursor="Hand"
                    MouseLeftButtonDown="GameHeader_Click"
                    Tag="PD2">
                <Grid Margin="15,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#x25BC;" 
                               FontSize="10" 
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Tag="CollapseIcon"/>
                    <TextBlock Grid.Column="1"
                               Text="PayDay 2" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ListBox x:Name="PD2ListBox"
                     ItemsSource="{Binding PD2Rooms}"
                     BorderThickness="0"
                     Background="Transparent"
                     ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                     ItemTemplate="{StaticResource RoomItemTemplate}"
                     SelectionMode="Single"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="RoomList_DoubleClick"/>

            <!-- Minecraft -->
            <Border Background="{DynamicResource HeaderBackground}" 
                    BorderBrush="{DynamicResource BorderColor}" 
                    BorderThickness="0,1,0,0"
                    Cursor="Hand"
                    MouseLeftButtonDown="GameHeader_Click"
                    Tag="MC">
                <Grid Margin="15,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#x25BC;" 
                               FontSize="10" 
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Tag="CollapseIcon"/>
                    <TextBlock Grid.Column="1"
                               Text="Minecraft" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ListBox x:Name="MCListBox"
                     ItemsSource="{Binding MCRooms}"
                     BorderThickness="0"
                     Background="Transparent"
                     ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                     ItemTemplate="{StaticResource RoomItemTemplate}"
                     SelectionMode="Single"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="RoomList_DoubleClick"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
