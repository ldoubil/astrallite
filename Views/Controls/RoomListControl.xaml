<UserControl x:Class="AstralLite.Views.Controls.RoomListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d">
    
    <UserControl.Resources>
        <DataTemplate x:Key="RoomItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Rectangle Width="3" Height="8" Fill="{DynamicResource SignalColor}" Margin="0,0,1,0"/>
                    <Rectangle Width="3" Height="12" Fill="{DynamicResource SignalColor}" Margin="0,0,1,0"/>
                    <Rectangle Width="3" Height="16" Fill="{DynamicResource SignalColor}" Margin="0,0,1,0"/>
                    <Rectangle Width="3" Height="20" Fill="{DynamicResource SignalColor}"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding RoomName}" 
                               FontSize="12" 
                               Foreground="{DynamicResource PrimaryText}"/>
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding TestIp}" 
                                   FontSize="10" 
                                   Foreground="{DynamicResource TertiaryText}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding GroupName}"
                                   FontSize="10"
                                   Foreground="{DynamicResource SignalColor}"
                                   Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>

                </Grid>
        </DataTemplate>
        
        <CollectionViewSource x:Key="GroupedRooms" Source="{Binding FilteredRooms}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource ListBackground}">
        <StackPanel Visibility="{Binding RoomListVisibility}">
            <ListBox ItemsSource="{Binding Source={StaticResource GroupedRooms}}"
                     BorderThickness="0"
                     Background="Transparent"
                     ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                     ItemTemplate="{StaticResource RoomItemTemplate}"
                     SelectionMode="Single"
                     SelectedItem="{Binding SelectedRoom}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="RoomList_DoubleClick">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource HeaderBackground}" 
                                        BorderBrush="{DynamicResource BorderColor}" 
                                        BorderThickness="0,1,0,0"
                                        Padding="15,8">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="12" 
                                               FontWeight="SemiBold" 
                                               Foreground="{DynamicResource PrimaryText}"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
            </ListBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
