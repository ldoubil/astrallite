<UserControl x:Class="AstralLite.Views.Controls.RoomListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d">
    
    <UserControl.Resources>
        <DataTemplate x:Key="RoomItemTemplate">
            <Grid>
                <TextBlock Text="{Binding RoomName}" 
                           FontSize="12" 
                           Foreground="{DynamicResource PrimaryText}"
                           VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
        
        <CollectionViewSource x:Key="GroupedRooms" Source="{Binding FilteredRooms}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource ListBackground}">
        <StackPanel Visibility="{Binding RoomListVisibility}">
            <ListBox ItemsSource="{Binding Source={StaticResource GroupedRooms}}"
                     BorderThickness="0"
                     Background="Transparent"
                     ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                     ItemTemplate="{StaticResource RoomItemTemplate}"
                     SelectionMode="Single"
                     SelectedItem="{Binding SelectedRoom}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="RoomList_DoubleClick">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource HeaderBackground}" 
                                        BorderBrush="{DynamicResource BorderColor}" 
                                        BorderThickness="0,1,0,0"
                                        Padding="15,8">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="12" 
                                               FontWeight="SemiBold" 
                                               Foreground="{DynamicResource PrimaryText}"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
            </ListBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
