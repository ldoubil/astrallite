<UserControl x:Class="AstralLite.Views.Controls.PlayerListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    
    <Grid>
        <ListBox ItemsSource="{Binding Players}"
                 BorderThickness="0"
                 Background="Transparent"
                 ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Visibility="{Binding PlayerListVisibility}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="12"
                                       Foreground="{DynamicResource PrimaryText}"/>
                            <Border Margin="6,0,0,0"
                                    Padding="4,1"
                                    CornerRadius="4"
                                    Background="{DynamicResource HeaderBackground}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TransportSummary}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TransportSummary}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding TransportSummary}"
                                           FontSize="9"
                                           Foreground="{DynamicResource AccentColor}"/>
                            </Border>
                            <Border Margin="6,0,0,0"
                                    Padding="4,1"
                                    CornerRadius="4"
                                    Background="{DynamicResource HeaderBackground}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LossRate}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LossRate}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding LossRate}"
                                           FontSize="9"
                                           Foreground="{DynamicResource SecondaryText}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Ping}"
                                       FontSize="10"
                                       Foreground="{DynamicResource SignalColor}"
                                       Margin="12,0,6,0"
                                       MouseEnter="PingText_MouseEnter"
                                       MouseLeave="PingText_MouseLeave"
                                       MouseMove="PingText_MouseMove"/>
                            
                            <TextBlock Text="{Binding ConnectionType}"
                                       FontSize="10"
                                       Foreground="{DynamicResource TertiaryText}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Popup x:Name="NatInfoPopup"
               Placement="Mouse"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="True">
            <Border Background="{DynamicResource HeaderBackground}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="2"
                    CornerRadius="6"
                    Padding="12,8">
                <Border.Effect>
                    <DropShadowEffect Color="Black" 
                                      Direction="270" 
                                      ShadowDepth="3" 
                                      BlurRadius="10" 
                                      Opacity="0.5"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock x:Name="NatInfoTitle"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentColor}"
                               Margin="0,0,0,6"/>
                    
                    <StackPanel x:Name="UdpNatPanel" Visibility="Collapsed">
                        <TextBlock Text="UDP NAT:" 
                                   FontSize="10" 
                                   Foreground="{DynamicResource SecondaryText}"
                                   Margin="0,0,0,2"/>
                        <TextBlock x:Name="UdpNatText"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}"
                                   Margin="0,0,0,6"/>
                    </StackPanel>
                    
                    <StackPanel x:Name="TcpNatPanel" Visibility="Collapsed">
                        <TextBlock Text="TCP NAT:" 
                                   FontSize="10" 
                                   Foreground="{DynamicResource SecondaryText}"
                                   Margin="0,0,0,2"/>
                        <TextBlock x:Name="TcpNatText"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
